{
  "name": "@decorify/core",
  "version": "0.1.0",
  "description": "Framework-agnostic HTTP backend framework with Stage 3 ES decorators.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "tsc --build tsconfig.build.json --watch --pretty",
    "clean": "node --eval \"fs.rmSync('dist', { recursive: true, force: true }); fs.rmSync('tsconfig.build.tsbuildinfo', { force: true })\"",
    "prepublishOnly": "pnpm clean && pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "decorators",
    "es-decorators",
    "stage-3",
    "typescript",
    "http",
    "backend",
    "framework",
    "routing",
    "middleware"
  ],
  "author": "Hossam Hamdy <hossamhamdy117@gmail.com>",
  "license": "ISC",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@decorify/di": "workspace:*",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@decorify/di": "workspace:^",
    "vitest": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@decorify/di": {
      "optional": false
    },
    "vitest": {
      "optional": true
    }
  },
  "homepage": "https://github.com/hossam7amdy/decorify#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/hossam7amdy/decorify",
    "directory": "packages/core"
  }
}
