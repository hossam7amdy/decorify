{
  "name": "decorify",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "pnpm -r --filter='./packages/*' build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --check .",
    "clean": "pnpm -r --filter='./packages/*' clean"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.26.2",
  "devDependencies": {
    "@decorify/di": "workspace:*",
    "@decorify/core": "workspace:*",
    "@decorify/express-adapter": "workspace:*",
    "@swc/core": "^1.15.21",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.1.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.2"
  }
}
